{
  "name": "locus",
  "version": "1.0.0",
  "description": "Agentic AI for Geospatial Intelligence and Situational Awareness",
  "main": "./out/main/index.js",
  "author": "Zeroz (CPE311 AI Lab)",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "news:serve": "node scripts/news-server.js",
    "build": "electron-vite build",
    "build:win": "npm run build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint . --ext .ts,.tsx",
    "scrape:explore": "set ELECTRON_RUN_AS_NODE=1 && electron node_modules/tsx/dist/cli.cjs scripts/scrapeExplorePlaces.ts",
    "scrape:explore:electron": "set ELECTRON_RUN_AS_NODE=1 && electron node_modules/tsx/dist/cli.cjs scripts/scrapeExplorePlaces.ts",
    "scrape:enrichment": "set ELECTRON_RUN_AS_NODE=1 && electron node_modules/tsx/dist/cli.cjs scripts/scrapers/enrichment-scraper.ts",
    "scrape:all": "npm run scrape:enrichment && npm run scrape:explore",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/topojson-client": "^3.1.5",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.9.0",
    "firebase": "^11.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.469.0",
    "prop-types": "^15.8.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.13.0",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.8.1",
    "sql.js": "^1.8.0"
  },
  "optionalDependencies": {
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "node-fetch": "^2.7.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.0",
    "@storybook/addon-a11y": "^10.2.1",
    "@storybook/addon-docs": "^10.2.1",
    "@storybook/addon-onboarding": "^10.2.1",
    "@storybook/addon-vitest": "^10.2.1",
    "@storybook/react-vite": "^10.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-storybook": "^10.2.1",
    "playwright": "^1.58.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.2.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.locus.app",
    "productName": "Locus",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "!**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      }
    },
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
