// Environment Variables Template
// Copy this file to .env and fill in your values

// n8n Webhook URL (via Ngrok tunnel)
VITE_NGROK_URL=https://your-tunnel.ngrok.io

// n8n API Key for authentication (IMPORTANT: Keep this secret!)
VITE_N8N_API_KEY=your_secure_api_key_here

// Firebase Configuration (optional, for cloud sync)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

// Map layer configuration (optional overrides)
VITE_MAP_THEME_SATELLITE_URL=https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}
VITE_MAP_LAYER_TRAFFIC_URL=https://mstraffic1.longdo.com/mmmap/tile.php?proj=epsg3857&mode=trafficoverlay&zoom={z}&x={x}&y={y}&key=YOUR_LONGDO_MAP_API_KEY
VITE_MAP_LAYER_RAIN_URL=
VITE_MAP_LAYER_FLOOD_RECURRENT_URL=https://ms.longdo.com/map/msn-server/tile.php?proj=epsg3857&mode=floodrecurrent&zoom={z}&x={x}&y={y}&HD=1&key=YOUR_LONGDO_MAP_API_KEY
// The next three settings apply only when VITE_MAP_LAYER_FLOOD_RECURRENT_URL points to a WMS endpoint.
VITE_MAP_LAYER_FLOOD_RECURRENT_LAYER=dri:c_dri_w1
VITE_MAP_LAYER_FLOOD_RECURRENT_STYLE=dri:dri_sld2023
VITE_MAP_LAYER_FLOOD_RECURRENT_FILTER=none
VITE_MAP_LAYER_RAIN_FILTER=saturate(1.2) contrast(1.12) brightness(1.02)
